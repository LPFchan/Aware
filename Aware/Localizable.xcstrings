      }
    },
    "tooltip.menu_bar" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Aware — Click to open menu" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Aware — クリックしてメニューを開く" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Aware — 클릭하여 메뉴 열기" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Aware — 点击打开菜单" } }
      }
    },
    "welcome.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Aware keeps your display awake by detecting your presence with the FaceTime camera. Click the person icon in the menu bar to enable." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "FaceTime カメラで在席を検出し、ディスプレイがスリープしないようにします。メニューバーの人物アイコンをクリックしてオンにします。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "FaceTime 카메라로 자리에 있는지 감지해 화면이 꺼지지 않게 합니다. 메뉴 막대의 사람 아이콘을 눌러 켜세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Aware 使用 FaceTime 摄像头检测您是否在场，从而保持显示器不熄屏。点击菜单栏中的人物图标以启用。" } }
      }
    },
    "welcome.checkbox" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Do not show this window again" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "このウィンドウを再度表示しない" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "이 창을 다시 표시하지 않음" } },
