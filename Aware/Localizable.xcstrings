        "ko" : { "stringUnit" : { "state" : "translated", "value" : "다른 앱이 화면을 켜 둠" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正由其他应用保持唤醒" } }
      }
    },
