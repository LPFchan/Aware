{
  "sourceLanguage" : "en",
  "strings" : {
    "accessibility.app_name" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Aware" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Aware" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Aware" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Aware" } }
      }
    },
    "alert.camera.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Aware needs camera access to detect your presence. Please enable it in System Settings > Privacy & Security > Camera." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "在席を検出するためにカメラへのアクセスが必要です。システム設定 › プライバシーとセキュリティ › カメラで許可してください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "자리에 있는지 확인하려면 카메라 접근이 필요합니다. 시스템 설정 > 개인정보 보호 및 보안 > 카메라에서 허용해 주세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Aware 需要访问摄像头以检测您是否在场。请在“系统设置”>“隐私与安全性”>“摄像头”中允许访问。" } }
      }
    },
    "alert.camera.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Camera Access Required" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "カメラへのアクセスが必要です" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "카메라 접근 필요" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "需要摄像头访问权限" } }
      }
    },
    "alert.ok" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "OK" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "OK" } },
